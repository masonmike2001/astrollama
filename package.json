		"@typescript-eslint/parser": "^8.63.0",
		"esbuild": "0.25.5",
		"eslint": "^9.39.5",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.7.0",
		"jiti": "^2.7.0",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.63.0"
	}
